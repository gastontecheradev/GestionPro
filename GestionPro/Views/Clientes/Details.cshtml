@model ClienteDetalleViewModel
@{
    ViewData["Title"] = Model.RazonSocial;
}

<div class="container py-4" style="max-width: 800px;">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Clientes" asp-action="Index">Clientes</a></li>
            <li class="breadcrumb-item active">@Model.RazonSocial</li>
        </ol>
    </nav>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0 fw-semibold">
                <i class="bi bi-person me-2"></i>@Model.RazonSocial
            </h4>
            <div class="btn-group btn-group-sm">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                    <i class="bi bi-pencil me-1"></i>Editar
                </a>
            </div>
        </div>
        <div class="card-body">
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase">Razón Social</label>
                        <p class="fw-medium mb-0">@Model.RazonSocial</p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase">RUT</label>
                        <p class="mb-0">@(Model.RUT ?? "No especificado")</p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase">Dirección</label>
                        <p class="mb-0">@(Model.Direccion ?? "No especificada")</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase">Teléfono</label>
                        <p class="mb-0">@(Model.Telefono ?? "No especificado")</p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase">Email</label>
                        <p class="mb-0">@(Model.Email ?? "No especificado")</p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase">Persona de Contacto</label>
                        <p class="mb-0">@(Model.Contacto ?? "No especificado")</p>
                    </div>
                </div>
            </div>

            <hr />

            <div class="row small text-muted">
                <div class="col-md-4">
                    <i class="bi bi-calendar me-1"></i>
                    Creado: @Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
                </div>
                <div class="col-md-4">
                    <i class="bi bi-clock me-1"></i>
                    Modificado: @(Model.FechaModificacion?.ToString("dd/MM/yyyy HH:mm") ?? "Nunca")
                </div>
                <div class="col-md-4">
                    <i class="bi bi-person me-1"></i>
                    Creado por: @(Model.CreadoPor ?? "Sistema")
                </div>
            </div>
        </div>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary mt-3">
        <i class="bi bi-arrow-left me-1"></i>Volver al listado
    </a>
</div>
