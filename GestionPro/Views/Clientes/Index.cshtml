@model GestionPro.Models.PagedList<ClienteListViewModel>
@{
    ViewData["Title"] = "Clientes";
}

<div class="container-fluid py-4 px-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-people me-2"></i>Clientes</h2>
            <p class="text-muted mb-0">@Model.TotalItemCount clientes registrados</p>
        </div>
        @if (User.IsInRole("Admin") || User.IsInRole("Vendedor"))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle me-2"></i>Nuevo Cliente
            </a>
        }
    </div>

    <!-- Search -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-3">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" name="busqueda" class="form-control"
                               placeholder="Buscar por razón social, RUT, email o contacto..."
                               value="@ViewBag.BusquedaActual" />
                    </div>
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-dark flex-fill">Buscar</button>
                    @if (!string.IsNullOrEmpty(ViewBag.BusquedaActual))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </div>
            </form>
        </div>
    </div>

    <!-- Table -->
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Razón Social</th>
                        <th>RUT</th>
                        <th>Teléfono</th>
                        <th>Email</th>
                        <th>Contacto</th>
                        <th class="text-center">Órdenes</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox display-6 d-block mb-2"></i>
                                @if (!string.IsNullOrEmpty(ViewBag.BusquedaActual))
                                {
                                    <span>No se encontraron clientes para "<strong>@ViewBag.BusquedaActual</strong>"</span>
                                }
                                else
                                {
                                    <span>No hay clientes registrados</span>
                                }
                            </td>
                        </tr>
                    }
                    @foreach (var cliente in Model)
                    {
                        <tr>
                            <td>
                                <a asp-action="Details" asp-route-id="@cliente.Id"
                                   class="text-decoration-none fw-medium">
                                    @cliente.RazonSocial
                                </a>
                            </td>
                            <td class="text-muted">@(cliente.RUT ?? "—")</td>
                            <td>@(cliente.Telefono ?? "—")</td>
                            <td>@(cliente.Email ?? "—")</td>
                            <td>@(cliente.Contacto ?? "—")</td>
                            <td class="text-center">
                                <span class="badge bg-secondary">@cliente.TotalOrdenes</span>
                            </td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@cliente.Id"
                                       class="btn btn-outline-secondary" title="Ver">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Vendedor"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@cliente.Id"
                                           class="btn btn-outline-primary" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    }
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <form asp-action="Delete" asp-route-id="@cliente.Id" method="post"
                                              class="d-inline"
                                              onsubmit="return confirm('¿Estás seguro de eliminar este cliente?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger" title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.PageCount > 1)
        {
            @await Html.PartialAsync("_Pagination", Model)
        }
    </div>
</div>
