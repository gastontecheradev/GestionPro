@{
    ViewData["Title"] = "Inicio";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GestionPro — Sistema de Gestión Empresarial</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
</head>
<body>

    <!-- ═══ NAVBAR ═══ -->
    <nav class="landing-nav">
        <div class="landing-nav-inner">
            <a href="/" class="landing-nav-logo">
                <i class="bi bi-box-seam"></i>GestionPro
            </a>
            <div class="landing-nav-links">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Dashboard" asp-action="Index" class="nav-link-landing">
                        <i class="bi bi-speedometer2 me-1"></i>Dashboard
                    </a>
                    <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
                        <button type="submit" class="nav-btn-register">
                            <i class="bi bi-box-arrow-right me-1"></i>Salir
                        </button>
                    </form>
                }
                else
                {
                    <a href="#demo" class="nav-link-landing">Demo</a>
                    <a href="#features" class="nav-link-landing">Funcionalidades</a>
                    <a asp-area="Identity" asp-page="/Account/Login" class="nav-btn-login">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Iniciar sesión
                    </a>
                }
            </div>
        </div>
    </nav>

    <!-- ═══ HERO ═══ -->
    <section class="hero">
        <div class="hero-content">
            <h1 class="anim anim-d1">
                Sistema de Gestión<br /><span>Empresarial</span>
            </h1>
            <p class="hero-subtitle anim anim-d2">
                Aplicación completa de distribución mayorista con gestión de clientes,
                productos, órdenes, facturación, roles y auditoría automática.
            </p>
            <div class="hero-actions anim anim-d3">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Dashboard" asp-action="Index" class="btn-hero btn-hero-primary">
                        <i class="bi bi-speedometer2"></i>Ir al Dashboard
                    </a>
                }
                else
                {
                    <a href="#demo" class="btn-hero btn-hero-primary">
                        <i class="bi bi-play-circle"></i>Probar Demo
                    </a>
                }
            </div>
        </div>
    </section>

    <!-- ═══ FEATURES ═══ -->
    <section class="features-section" id="features">
        <div class="features-header">
            <h2>Funcionalidades del Sistema</h2>
            <p>Todo lo que una empresa de distribución necesita, en una sola aplicación</p>
        </div>
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon blue"><i class="bi bi-people"></i></div>
                <h5>Gestión de Clientes</h5>
                <p>CRUD completo con búsqueda en tiempo real, paginación server-side y soft delete para mantener integridad.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon green"><i class="bi bi-box-seam"></i></div>
                <h5>Productos y Stock</h5>
                <p>Control de inventario con alertas de stock mínimo, categorías, códigos SKU y filtros avanzados.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon amber"><i class="bi bi-cart3"></i></div>
                <h5>Órdenes Dinámicas</h5>
                <p>Creación con líneas dinámicas vía JavaScript, cálculo automático de IVA (22%), y gestión de estados.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon red"><i class="bi bi-receipt"></i></div>
                <h5>Facturación</h5>
                <p>Generación desde órdenes aprobadas con numeración correlativa, control de pagos e impresión.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon navy"><i class="bi bi-shield-lock"></i></div>
                <h5>Roles y Permisos</h5>
                <p>Tres niveles de acceso (Admin, Vendedor, Viewer) con ASP.NET Identity y autorización por atributos.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon purple"><i class="bi bi-clock-history"></i></div>
                <h5>Auditoría Automática</h5>
                <p>Registro de cada cambio en JSON: quién modificó qué, cuándo, con valores anteriores y nuevos.</p>
            </div>
        </div>
    </section>

    <!-- ═══ DEMO ACCESS ═══ -->
    <section class="demo-section" id="demo">
        <div class="demo-content">
            <h2>Probá el Sistema</h2>
            <p>Elegí un rol para explorar el sistema. La demo es de solo lectura para proteger los datos.</p>

            <form method="post" action="/Identity/Account/Login" id="demoForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Input.Email" id="demoEmail" />
                <input type="hidden" name="Input.Password" id="demoPassword" />
                <input type="hidden" name="Input.RememberMe" value="false" />

                <div class="demo-cards">
                    <div class="demo-card admin" onclick="submitDemo('admin@@gestionpro.com', 'Admin123!')">
                        <div class="demo-card-header">
                            <span class="demo-card-role"><i class="bi bi-shield-fill me-1"></i>Admin</span>
                            <span class="demo-card-badge">Acceso total</span>
                        </div>
                        <ul class="demo-card-perms">
                            <li><i class="bi bi-check-lg"></i>Dashboard con métricas</li>
                            <li><i class="bi bi-check-lg"></i>CRUD de clientes y productos</li>
                            <li><i class="bi bi-check-lg"></i>Crear y gestionar órdenes</li>
                            <li><i class="bi bi-check-lg"></i>Generar facturas</li>
                            <li><i class="bi bi-check-lg"></i>Eliminar registros</li>
                        </ul>
                        <button type="button" class="demo-card-btn">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Entrar como Admin
                        </button>
                    </div>

                    <div class="demo-card vendedor" onclick="submitDemo('vendedor@@gestionpro.com', 'Vendedor123!')">
                        <div class="demo-card-header">
                            <span class="demo-card-role"><i class="bi bi-person-badge me-1"></i>Vendedor</span>
                            <span class="demo-card-badge">Operativo</span>
                        </div>
                        <ul class="demo-card-perms">
                            <li><i class="bi bi-check-lg"></i>Dashboard con métricas</li>
                            <li><i class="bi bi-check-lg"></i>Crear y editar clientes</li>
                            <li><i class="bi bi-check-lg"></i>Crear y editar productos</li>
                            <li><i class="bi bi-check-lg"></i>Crear órdenes</li>
                            <li><i class="bi bi-x-lg"></i>No puede eliminar registros</li>
                        </ul>
                        <button type="button" class="demo-card-btn">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Entrar como Vendedor
                        </button>
                    </div>
                </div>
            </form>

            <div class="demo-readonly-note">
                <i class="bi bi-lock-fill"></i>
                Demo de solo lectura — los datos no se modifican
            </div>
        </div>
    </section>

    <!-- ═══ FOOTER ═══ -->
    <footer class="landing-footer">
        <p>
            Desarrollado por <strong>Gastón Techera</strong>
            <a href="https://github.com/gastontecheradev" target="_blank"><i class="bi bi-github"></i> GitHub</a>
            <a href="https://www.linkedin.com/in/gaston-techera-dev/" target="_blank"><i class="bi bi-linkedin"></i> LinkedIn</a>
        </p>
    </footer>

    <script>
        function submitDemo(email, password) {
            document.getElementById('demoEmail').value = email;
            document.getElementById('demoPassword').value = password;
            document.getElementById('demoForm').submit();
        }

        document.querySelectorAll('a[href^="#"]').forEach(a => {
            a.addEventListener('click', e => {
                e.preventDefault();
                const target = document.querySelector(a.getAttribute('href'));
                if (target) target.scrollIntoView({ behavior: 'smooth' });
            });
        });
    </script>
</body>
</html>
