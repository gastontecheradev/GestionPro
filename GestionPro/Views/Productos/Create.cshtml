@model ProductoFormViewModel
@{
    ViewData["Title"] = "Nuevo Producto";
}

<div class="container py-4" style="max-width: 800px;">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Productos" asp-action="Index" data-i18n="nav.productos">Productos</a></li>
            <li class="breadcrumb-item active" data-i18n="common.nuevo">Nuevo</li>
        </ol>
    </nav>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white">
            <h4 class="mb-0 fw-semibold">
                <i class="bi bi-box-seam me-2"></i><span data-i18n="productos.nuevo">Nuevo Producto</span>
            </h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <partial name="_Form" model="Model" />
                <div class="d-flex gap-2 mt-4 pt-3 border-top">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i><span data-i18n="productos.crear">Crear Producto</span>
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary" data-i18n="common.cancelar">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
