@model ProductoDetalleViewModel
@{
    ViewData["Title"] = Model.Nombre;
}

<div class="container py-4" style="max-width: 800px;">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Productos" asp-action="Index" data-i18n="nav.productos">Productos</a></li>
            <li class="breadcrumb-item active">@Model.Nombre</li>
        </ol>
    </nav>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0 fw-semibold">
                <i class="bi bi-box me-2"></i>@Model.Nombre
            </h4>
            @if (User.IsInRole("Admin") || User.IsInRole("Vendedor"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-pencil me-1"></i><span data-i18n="common.editar">Editar</span>
                </a>
            }
        </div>
        <div class="card-body">
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase" data-i18n="productos.thNombre">Nombre</label>
                        <p class="fw-medium mb-0">@Model.Nombre</p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase" data-i18n="productos.thCodigo">Código</label>
                        <p class="mb-0 font-monospace">@(Model.Codigo ?? "—")</p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase" data-i18n="productos.thCategoria">Categoría</label>
                        <p class="mb-0">@(Model.CategoriaNombre ?? "—")</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase" data-i18n="productos.thPrecio">Precio</label>
                        <p class="mb-0 fw-semibold">$@Model.Precio.ToString("N2")</p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase" data-i18n="productos.thStock">Stock</label>
                        <p class="mb-0">
                            @if (Model.StockBajo)
                            {
                                <span class="badge bg-danger me-1">@Model.Stock</span>
                                <span class="text-danger small" data-i18n="productos.estadoStockBajo">Stock bajo</span>
                            }
                            else
                            {
                                <span class="badge bg-success me-1">@Model.Stock</span>
                                <span class="text-success small" data-i18n="productos.estadoOk">OK</span>
                            }
                        </p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase" data-i18n="productos.thEstado">Estado</label>
                        <p class="mb-0 text-muted small" data-i18n="productos.stockMinimo">Stock mínimo: @Model.StockMinimo</p>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Descripcion))
                {
                    <div class="col-12">
                        <label class="form-label text-muted small text-uppercase" data-i18n="form.descripcionPlaceholder">Descripción</label>
                        <p class="mb-0">@Model.Descripcion</p>
                    </div>
                }
            </div>

            <hr />

            <div class="row small text-muted">
                <div class="col-md-4">
                    <i class="bi bi-calendar me-1"></i>
                    <span data-i18n="detail.creado">Creado</span>: @Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
                </div>
                <div class="col-md-4">
                    <i class="bi bi-clock me-1"></i>
                    <span data-i18n="detail.modificado">Modificado</span>: @(Model.FechaModificacion?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                </div>
                <div class="col-md-4">
                    <i class="bi bi-person me-1"></i>
                    <span data-i18n="detail.creadoPor">Creado por</span>: @(Model.CreadoPor ?? "Sistema")
                </div>
            </div>
        </div>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary mt-3">
        <i class="bi bi-arrow-left me-1"></i><span data-i18n="common.volver">Volver al listado</span>
    </a>
</div>
