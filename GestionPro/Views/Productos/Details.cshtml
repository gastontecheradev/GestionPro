@model ProductoDetalleViewModel
@{
    ViewData["Title"] = Model.Nombre;
}

<div class="container py-4" style="max-width: 800px;">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Productos" asp-action="Index">Productos</a></li>
            <li class="breadcrumb-item active">@Model.Nombre</li>
        </ol>
    </nav>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0 fw-semibold">
                <i class="bi bi-box me-2"></i>@Model.Nombre
            </h4>
            <div class="btn-group btn-group-sm">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                    <i class="bi bi-pencil me-1"></i>Editar
                </a>
            </div>
        </div>
        <div class="card-body">
            <!-- Stock alert -->
            @if (Model.StockBajo)
            {
                <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <div>
                        <strong>Stock bajo.</strong> Este producto tiene @Model.Stock unidades
                        (mínimo configurado: @Model.StockMinimo).
                    </div>
                </div>
            }

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase">Nombre</label>
                        <p class="fw-medium mb-0">@Model.Nombre</p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase">Código (SKU)</label>
                        <p class="mb-0">
                            @if (!string.IsNullOrEmpty(Model.Codigo))
                            {
                                <span class="badge bg-light text-dark border font-monospace">@Model.Codigo</span>
                            }
                            else
                            {
                                <span class="text-muted">No especificado</span>
                            }
                        </p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase">Categoría</label>
                        <p class="mb-0">@Model.CategoriaNombre</p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase">Descripción</label>
                        <p class="mb-0">@(Model.Descripcion ?? "Sin descripción")</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label text-muted small text-uppercase">Precio</label>
                        <p class="fw-bold fs-4 mb-0 text-primary">$@Model.Precio.ToString("N2")</p>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label text-muted small text-uppercase">Stock Actual</label>
                            <p class="fw-bold fs-4 mb-0 @(Model.StockBajo ? "text-danger" : "text-success")">
                                @Model.Stock
                            </p>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label text-muted small text-uppercase">Stock Mínimo</label>
                            <p class="fw-bold fs-4 mb-0">@Model.StockMinimo</p>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                    {
                        <div class="mb-3">
                            <label class="form-label text-muted small text-uppercase">Imagen</label>
                            <img src="@Model.ImagenUrl" alt="@Model.Nombre"
                                 class="img-fluid rounded border" style="max-height: 200px;" />
                        </div>
                    }
                </div>
            </div>

            <hr />

            <div class="row small text-muted">
                <div class="col-md-4">
                    <i class="bi bi-calendar me-1"></i>
                    Creado: @Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
                </div>
                <div class="col-md-4">
                    <i class="bi bi-clock me-1"></i>
                    Modificado: @(Model.FechaModificacion?.ToString("dd/MM/yyyy HH:mm") ?? "Nunca")
                </div>
                <div class="col-md-4">
                    <i class="bi bi-person me-1"></i>
                    Creado por: @(Model.CreadoPor ?? "Sistema")
                </div>
            </div>
        </div>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary mt-3">
        <i class="bi bi-arrow-left me-1"></i>Volver al listado
    </a>
</div>
