@model GestionPro.Models.PagedList<ProductoListViewModel>
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Productos";
    var categorias = ViewBag.Categorias as List<SelectListItem> ?? new List<SelectListItem>();
}

<div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-box me-2"></i>Productos</h2>
            <p class="text-muted mb-0">@Model.TotalItemCount productos registrados</p>
        </div>
        @if (User.IsInRole("Admin") || User.IsInRole("Vendedor"))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle me-2"></i>Nuevo Producto
            </a>
        }
    </div>

    <!-- Filters -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-3">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" name="busqueda" class="form-control"
                               placeholder="Buscar por nombre, código..."
                               value="@ViewBag.BusquedaActual" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="categoriaId" class="form-select">
                        <option value="">Todas las categorías</option>
                        @foreach (var cat in categorias)
                        {
                            var selected = ViewBag.CategoriaActual?.ToString() == cat.Value;
                            <option value="@cat.Value" selected="@selected">@cat.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <div class="form-check mt-2">
                        <input type="checkbox" name="stockBajo" value="true"
                               class="form-check-input" id="chkStock"
                               @(ViewBag.StockBajoActual == true ? "checked" : "") />
                        <label class="form-check-label" for="chkStock">
                            <i class="bi bi-exclamation-triangle text-danger me-1"></i>Stock bajo
                        </label>
                    </div>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-dark flex-fill">Filtrar</button>
                    @if (!string.IsNullOrEmpty(ViewBag.BusquedaActual) ||
                         ViewBag.CategoriaActual != null ||
                         ViewBag.StockBajoActual == true)
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </div>
            </form>
        </div>
    </div>

    <!-- Table -->
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Código</th>
                        <th>Nombre</th>
                        <th>Categoría</th>
                        <th class="text-end">Precio</th>
                        <th class="text-center">Stock</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox display-6 d-block mb-2"></i>
                                <span>No se encontraron productos</span>
                            </td>
                        </tr>
                    }
                    @foreach (var prod in Model)
                    {
                        <tr class="@(prod.StockBajo ? "table-warning" : "")">
                            <td>
                                <span class="badge bg-light text-dark border font-monospace">
                                    @(prod.Codigo ?? "—")
                                </span>
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@prod.Id"
                                   class="text-decoration-none fw-medium">
                                    @prod.Nombre
                                </a>
                            </td>
                            <td class="text-muted">@prod.CategoriaNombre</td>
                            <td class="text-end fw-medium">$@prod.Precio.ToString("N2")</td>
                            <td class="text-center">
                                @if (prod.StockBajo)
                                {
                                    <span class="badge bg-danger">@prod.Stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@prod.Stock</span>
                                }
                            </td>
                            <td>
                                @if (prod.StockBajo)
                                {
                                    <span class="text-danger small">
                                        <i class="bi bi-exclamation-triangle me-1"></i>Stock bajo
                                    </span>
                                }
                                else
                                {
                                    <span class="text-success small">
                                        <i class="bi bi-check-circle me-1"></i>OK
                                    </span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@prod.Id"
                                       class="btn btn-outline-secondary" title="Ver">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Vendedor"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@prod.Id"
                                           class="btn btn-outline-primary" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    }
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <form asp-action="Delete" asp-route-id="@prod.Id" method="post"
                                              class="d-inline"
                                              onsubmit="return confirm('¿Estás seguro de eliminar este producto?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger" title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.PageCount > 1)
        {
            @await Html.PartialAsync("_Pagination", Model)
        }
    </div>
</div>
