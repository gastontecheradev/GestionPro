@model CategoriaFormViewModel

<div class="row g-3">
    <div class="col-12">
        <label asp-for="Nombre" class="form-label"></label>
        <input asp-for="Nombre" class="form-control"
               data-i18n-placeholder="form.categoriaNombrePlaceholder"
               placeholder="Ej: Bebidas" />
        <span asp-validation-for="Nombre" class="text-danger small"></span>
    </div>
    <div class="col-12">
        <label asp-for="Descripcion" class="form-label"></label>
        <textarea asp-for="Descripcion" class="form-control" rows="3"
                  data-i18n-placeholder="form.categoriaDescPlaceholder"
                  placeholder="Descripción breve de la categoría..."></textarea>
        <span asp-validation-for="Descripcion" class="text-danger small"></span>
    </div>
</div>
