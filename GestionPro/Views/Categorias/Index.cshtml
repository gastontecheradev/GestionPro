@model GestionPro.Models.PagedList<CategoriaListViewModel>
@{
    ViewData["Title"] = "Categorías";
}

<div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-tags me-2"></i><span data-i18n="categorias.title">Categorías</span></h2>
            <p class="text-muted mb-0">@Model.TotalItemCount <span data-i18n="categorias.registradas">categorías registradas</span></p>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle me-2"></i><span data-i18n="categorias.nueva">Nueva Categoría</span>
            </a>
        }
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-3">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" name="busqueda" class="form-control"
                               data-i18n-placeholder="categorias.buscarPlaceholder"
                               placeholder="Buscar por nombre o descripción..."
                               value="@ViewBag.BusquedaActual" />
                    </div>
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-dark flex-fill" data-i18n="categorias.buscar">Buscar</button>
                    @if (!string.IsNullOrEmpty(ViewBag.BusquedaActual))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th data-i18n="categorias.thNombre">Nombre</th>
                        <th data-i18n="categorias.thDescripcion">Descripción</th>
                        <th class="text-center" data-i18n="categorias.thProductos">Productos</th>
                        <th data-i18n="categorias.thCreacion">Creación</th>
                        <th class="text-end" data-i18n="categorias.thAcciones">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox display-6 d-block mb-2"></i>
                                @if (!string.IsNullOrEmpty(ViewBag.BusquedaActual))
                                {
                                    <span data-i18n="categorias.sinResultados">No se encontraron categorías</span>
                                }
                                else
                                {
                                    <span data-i18n="categorias.sinRegistros">No hay categorías registradas</span>
                                }
                            </td>
                        </tr>
                    }
                    @foreach (var cat in Model)
                    {
                        <tr>
                            <td class="fw-medium">@cat.Nombre</td>
                            <td class="text-muted">@(cat.Descripcion ?? "—")</td>
                            <td class="text-center">
                                <span class="badge bg-secondary">@cat.TotalProductos</span>
                            </td>
                            <td class="text-muted small">@cat.FechaCreacion.ToString("dd/MM/yyyy")</td>
                            <td class="text-end">
                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Edit" asp-route-id="@cat.Id"
                                           class="btn btn-outline-primary" data-i18n-title="common.editar" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@cat.Id" method="post"
                                              class="d-inline"
                                              data-i18n-confirm="categorias.confirmarEliminar"
                                              onsubmit="return confirm('¿Estás seguro de eliminar esta categoría?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger" title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.PageCount > 1)
        {
            @await Html.PartialAsync("_Pagination", Model)
        }
    </div>
</div>
