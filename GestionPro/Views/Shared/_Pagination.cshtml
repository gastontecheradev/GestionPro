@*
   Partial de paginación reutilizable.
   Recibe cualquier PagedList<T> como Model.
*@

@{
    dynamic pagedList = Model;
    if (pagedList == null || pagedList.PageCount <= 1) return;

    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";
}

<div class="card-footer bg-white d-flex justify-content-between align-items-center">
    <small class="text-muted">
        Mostrando @pagedList.FirstItemOnPage–@pagedList.LastItemOnPage de @pagedList.TotalItemCount
    </small>
    <nav>
        <ul class="pagination pagination-sm mb-0">
            @if (pagedList.HasPreviousPage)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Action(currentAction, new { pagina = pagedList.PageNumber - 1 })">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link"><i class="bi bi-chevron-left"></i></span>
                </li>
            }

            @{
                int startPage = Math.Max(1, (int)pagedList.PageNumber - 2);
                int endPage = Math.Min((int)pagedList.PageCount, (int)pagedList.PageNumber + 2);

                if (startPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action(currentAction, new { pagina = 1 })">1</a>
                    </li>
                    if (startPage > 2)
                    {
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    }
                }

                for (int i = startPage; i <= endPage; i++)
                {
                    if (i == (int)pagedList.PageNumber)
                    {
                        <li class="page-item active"><span class="page-link">@i</span></li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action(currentAction, new { pagina = i })">@i</a>
                        </li>
                    }
                }

                if (endPage < (int)pagedList.PageCount)
                {
                    if (endPage < (int)pagedList.PageCount - 1)
                    {
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    }
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action(currentAction, new { pagina = pagedList.PageCount })">@pagedList.PageCount</a>
                    </li>
                }
            }

            @if (pagedList.HasNextPage)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Action(currentAction, new { pagina = pagedList.PageNumber + 1 })">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link"><i class="bi bi-chevron-right"></i></span>
                </li>
            }
        </ul>
    </nav>
</div>
