@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container py-5 text-center">
    <h1 class="text-danger"><i class="bi bi-exclamation-triangle"></i></h1>
    <h2>Ocurrió un error</h2>
    <p class="text-muted">Lo sentimos, algo salió mal al procesar tu solicitud.</p>

    @if (Model?.ShowRequestId ?? false)
    {
        <p class="small text-muted">
            <strong>Request ID:</strong> <code>@Model?.RequestId</code>
        </p>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
        <i class="bi bi-house me-2"></i>Volver al inicio
    </a>
</div>
