@model GestionPro.Models.PagedList<OrdenListViewModel>
@{
    ViewData["Title"] = "Órdenes";
}

<div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-cart3 me-2"></i>Órdenes</h2>
            <p class="text-muted mb-0">@Model.TotalItemCount órdenes registradas</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>Nueva Orden
        </a>
    </div>

    <!-- Filters -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-3">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" name="busqueda" class="form-control"
                               placeholder="Buscar por número de orden o cliente..."
                               value="@ViewBag.BusquedaActual" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="estado" class="form-select">
                        <option value="">Todos los estados</option>
                        @foreach (EstadoOrden e in Enum.GetValues(typeof(EstadoOrden)))
                        {
                            var selected = ViewBag.EstadoActual != null &&
                                           (EstadoOrden)ViewBag.EstadoActual == e;
                            <option value="@((int)e)" selected="@selected">@e</option>
                        }
                    </select>
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-dark flex-fill">Filtrar</button>
                    @if (!string.IsNullOrEmpty(ViewBag.BusquedaActual) || ViewBag.EstadoActual != null)
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </div>
            </form>
        </div>
    </div>

    <!-- Table -->
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nº Orden</th>
                        <th>Cliente</th>
                        <th>Fecha</th>
                        <th class="text-center">Líneas</th>
                        <th class="text-end">Total</th>
                        <th>Estado</th>
                        <th class="text-center">Factura</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox display-6 d-block mb-2"></i>
                                <span>No se encontraron órdenes</span>
                            </td>
                        </tr>
                    }
                    @foreach (var orden in Model)
                    {
                        var badgeClass = orden.Estado switch
                        {
                            EstadoOrden.Pendiente => "bg-warning text-dark",
                            EstadoOrden.Aprobada => "bg-info",
                            EstadoOrden.EnPreparacion => "bg-primary",
                            EstadoOrden.Enviada => "bg-secondary",
                            EstadoOrden.Entregada => "bg-success",
                            EstadoOrden.Cancelada => "bg-danger",
                            _ => "bg-secondary"
                        };
                        <tr class="@(orden.Estado == EstadoOrden.Cancelada ? "table-secondary" : "")">
                            <td>
                                <a asp-action="Details" asp-route-id="@orden.Id"
                                   class="text-decoration-none fw-medium font-monospace">
                                    @orden.NumeroOrden
                                </a>
                            </td>
                            <td>@orden.ClienteNombre</td>
                            <td class="text-muted">@orden.FechaOrden.ToString("dd/MM/yyyy")</td>
                            <td class="text-center">@orden.TotalLineas</td>
                            <td class="text-end fw-medium">$@orden.Total.ToString("N2")</td>
                            <td><span class="badge @badgeClass">@orden.Estado</span></td>
                            <td class="text-center">
                                @if (orden.TieneFactura)
                                {
                                    <i class="bi bi-check-circle-fill text-success" title="Facturada"></i>
                                }
                                else
                                {
                                    <i class="bi bi-dash text-muted"></i>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@orden.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye me-1"></i>Ver
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.PageCount > 1)
        {
            @await Html.PartialAsync("_Pagination", Model)
        }
    </div>
</div>
