@page
@model GestionPro.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar sesión — GestionPro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        body {
            font-family: 'Inter', system-ui, sans-serif;
            background: #f1f5f9;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
            -webkit-font-smoothing: antialiased;
        }
        .login-card {
            width: 100%;
            max-width: 420px;
            background: #fff;
            border-radius: .75rem;
            box-shadow: 0 10px 40px rgba(0,0,0,.06), 0 1px 3px rgba(0,0,0,.04);
            padding: 2.5rem;
        }
        .login-logo { text-align: center; margin-bottom: 1.5rem; }
        .login-logo a { font-size: 1.3rem; font-weight: 700; color: #1e293b; text-decoration: none; letter-spacing: -.02em; }
        .login-logo a i { color: #3b82f6; }
        .login-title { text-align: center; font-size: 1.15rem; font-weight: 700; color: #1e293b; margin-bottom: .25rem; }
        .login-subtitle { text-align: center; font-size: .82rem; color: #94a3b8; margin-bottom: 1.5rem; }
        .form-label { font-size: .78rem; font-weight: 600; color: #64748b; }
        .form-control { border: 1.5px solid #e2e8f0; border-radius: .5rem; padding: .6rem .85rem; font-size: .88rem; }
        .form-control:focus { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,.12); }
        .btn-login { width: 100%; background: #3b82f6; border: none; color: #fff; font-weight: 600; padding: .65rem; border-radius: .5rem; font-size: .88rem; transition: all .2s; }
        .btn-login:hover { background: #2563eb; color: #fff; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(59,130,246,.3); }
        .divider { text-align: center; margin: 1.5rem 0; position: relative; }
        .divider::before { content: ''; position: absolute; top: 50%; left: 0; right: 0; height: 1px; background: #e2e8f0; }
        .divider span { background: #fff; padding: 0 .75rem; font-size: .72rem; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: .08em; position: relative; }
        .demo-buttons { display: flex; flex-direction: column; gap: .5rem; }
        .btn-demo { display: flex; align-items: center; justify-content: space-between; width: 100%; padding: .6rem 1rem; border: 1.5px solid #e2e8f0; border-radius: .5rem; background: #f8fafc; color: #1e293b; font-size: .82rem; font-weight: 600; cursor: pointer; transition: all .2s; }
        .btn-demo:hover { border-color: #3b82f6; background: rgba(59,130,246,.04); transform: translateY(-1px); }
        .btn-demo .badge-role { font-size: .6rem; padding: .2em .5em; border-radius: .2rem; font-weight: 700; }
        .btn-demo.admin .badge-role { background: #fee2e2; color: #dc2626; }
        .btn-demo.vendedor .badge-role { background: #dbeafe; color: #2563eb; }
        .login-footer { text-align: center; margin-top: 1.25rem; font-size: .82rem; color: #94a3b8; }
        .login-footer a { color: #3b82f6; text-decoration: none; font-weight: 600; }
        .login-footer a:hover { text-decoration: underline; }
        .readonly-note { text-align: center; margin-top: .75rem; font-size: .7rem; color: #94a3b8; }
        .text-danger { font-size: .8rem; }

        /* Lang toggle en login */
        .login-lang {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 1rem;
        }
        .gp-lang-toggle {
            display: flex;
            align-items: center;
            background: #f1f5f9;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
            overflow: hidden;
            height: 26px;
        }
        .gp-lang-toggle [data-lang] {
            display: flex; align-items: center; justify-content: center;
            padding: 0 9px; height: 100%;
            font-size: .68rem; font-weight: 600; letter-spacing: .04em;
            color: #94a3b8; cursor: pointer; text-decoration: none;
            transition: background .15s, color .15s;
            border: none; background: transparent; line-height: 1;
        }
        .gp-lang-toggle [data-lang]:hover { color: #475569; background: #e2e8f0; }
        .gp-lang-toggle [data-lang].active { background: #3b82f6; color: #fff; }
        .gp-lang-toggle .lang-divider { width: 1px; height: 12px; background: #e2e8f0; flex-shrink: 0; }
    </style>
</head>
<body>
    <div class="login-card">

        <!-- Lang toggle -->
        <div class="login-lang">
            <div class="gp-lang-toggle" title="Language / Idioma">
                <button data-lang="es" class="active">ES</button>
                <span class="lang-divider"></span>
                <button data-lang="en">EN</button>
            </div>
        </div>

        <div class="login-logo">
            <a href="/"><i class="bi bi-box-seam me-2"></i>GestionPro</a>
        </div>

        <h2 class="login-title" data-i18n="login.titulo">Iniciar sesión</h2>
        <p class="login-subtitle" data-i18n="login.subtitulo">Ingresá tus credenciales</p>

        <form id="loginForm" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label" data-i18n="login.email">Email</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username"
                       data-i18n-placeholder="login.emailPlaceholder"
                       placeholder="tu@email.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label" data-i18n="login.contrasena">Contraseña</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password"
                       placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="Input.RememberMe" class="form-check-input" />
                <label asp-for="Input.RememberMe" class="form-check-label" style="font-size:.82rem;" data-i18n="login.recordarme">
                    Recordarme
                </label>
            </div>

            <button type="submit" class="btn btn-login">
                <i class="bi bi-box-arrow-in-right me-2"></i><span data-i18n="nav.iniciarSesion">Iniciar sesión</span>
            </button>
        </form>

        <div class="divider"><span data-i18n="login.oAccesoRapido">o acceso rápido</span></div>

        <div class="demo-buttons">
            <button type="button" class="btn-demo admin"
                    onclick="loginDemo('admin@@gestionpro.com', 'Admin123!')">
                <span><i class="bi bi-shield-fill me-2"></i><span data-i18n="landing.demoEnterAdmin">Entrar como Admin</span></span>
                <span class="badge-role">Admin</span>
            </button>
            <button type="button" class="btn-demo vendedor"
                    onclick="loginDemo('vendedor@@gestionpro.com', 'Vendedor123!')">
                <span><i class="bi bi-person-badge me-2"></i><span data-i18n="landing.demoEnterVendedor">Entrar como Vendedor</span></span>
                <span class="badge-role">Vendedor</span>
            </button>
        </div>

        <p class="readonly-note">
            <i class="bi bi-lock-fill me-1"></i><span data-i18n="landing.demoReadonly">Demo de solo lectura</span>
        </p>

        <div class="login-footer">
            <a href="/">← <span data-i18n="login.volverInicio">Volver al inicio</span></a>
        </div>
    </div>

    <script>
        function loginDemo(email, password) {
            document.getElementById('Input_Email').value = email;
            document.getElementById('Input_Password').value = password;
            document.getElementById('loginForm').submit();
        }
    </script>

    <script src="/js/i18n.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
